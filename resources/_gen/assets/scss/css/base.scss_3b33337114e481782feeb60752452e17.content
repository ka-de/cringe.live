de__toggle:after{content:attr(data-label-expand)}.collapsible-code label{position:relative;display:flex;justify-content:space-between;min-width:30px;min-height:30px;margin:0;border-bottom:1px solid #edbd7a;cursor:pointer}.collapsible-code__title{flex:1;color:#f6c177;padding:3px 10px;text-overflow:ellipsis;white-space:nowrap;overflow:hidden}.collapsible-code__language{color:#f6c177;border:1px solid #edbd7a;border-bottom:none;text-transform:uppercase;padding:3px 10px}.collapsible-code__toggle{color:#f6c177;font-size:16px;padding:3px 10px}.collapsible-code__toggle:after{content:attr(data-label-collapse)}.collapsible-code pre{margin-top:0}.collapsible-code pre::first-line{line-height:0}.collapsible-code .code-toolbar{margin:0}.terms h3{font-size:initial}.terms ul{list-style:none}.terms ul li a{color:#f6c177}.terms ul li:not(:empty):before{content:'-';position:absolute;left:-20px;color:#f6c177}body .gist .blob-num,body .gist .blob-code-inner{border:none}.sentence-container{display:grid;grid-template-columns:auto 1fr auto;align-items:flex-start;margin-bottom:10px;overflow-y:hidden;transition:max-height 0.3s ease-in-out}#randomizeButton{margin:35px auto 0 auto}.changeSentence{cursor:pointer;color:#f6c177;padding:0 10px;white-space:nowrap;transition:padding 0.3s ease-in-out, margin-left 0.3s ease-in-out;font-size:1em}.sentence-text{overflow:hidden;text-overflow:ellipsis;flex-grow:1;transition:flex-grow 0.3s ease-in-out, overflow 0.3s ease-in-out;font-size:1.2rem}@media (max-width: 600px){.sentence-container span{padding:5px}.sentence-container span+span{margin-left:5px}}

